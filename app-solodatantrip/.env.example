# Obrigatório em produção (Vercel): gere com openssl rand -base64 32
AUTH_SECRET=

# PostgreSQL (obrigatório para login e cadastro)
# Prisma: DATABASE_URL = pool (runtime) | DIRECT_URL = conexão direta (migrations)
#
# --- Neon (integração Vercel Storage) ---
# A Vercel injeta POSTGRES_URL e POSTGRES_URL_NON_POOLING; o build mapeia automaticamente.
# Opcional: copie os mesmos valores para DATABASE_URL e DIRECT_URL.
#
# Manual Neon:
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require
# DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require
#
# --- Supabase ---
# DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
#
# --- Docker local (docker compose up db) ---
# DATABASE_URL=postgresql://datageo:datageo@localhost:5433/datageo
# DIRECT_URL=postgresql://datageo:datageo@localhost:5433/datageo
DATABASE_URL=
DIRECT_URL=

# Admin inicial (npm run db:seed) — altere ADMIN_PASSWORD na Vercel antes do seed em produção
ADMIN_EMAIL=admin@datageo.com.br
ADMIN_PASSWORD=
ADMIN_NAME=Administrador Datageo

# Admin API (dashboard RTK) — Authorization: Bearer ADMIN_SECRET
# ADMIN_SECRET=

# Mapa de cobertura: /api/coverage (proxy Geodnet, sem Data Cache Next.js)
# Geocoding: /api/geocoding/search (proxy Nominatim, paginação limit/offset)

# Provisionamento RTK (RTK Data Reseller API)
# Sandbox (padrão): RTK_API_MODE=test
# Produção futura: RTK_API_MODE=production + RTK_API_URL_PRODUCTION + RTK_API_KEY_PRODUCTION
RTK_API_URL=https://rtkdata-reseller-1.onrender.com/api/v1/provision
RTK_API_KEY=
RTK_API_MODE=test
RTK_DEFAULT_PLAN=trial

# Trial gratuito no cadastro (dias)
TRIAL_DURATION_DAYS=30

# Chave dedicada para criptografar senhas RTK no banco (recomendado em produção)
# RTK_ENCRYPTION_KEY=

# Cron diário — verificação de expiração de licenças RTK
# CRON_SECRET=

# Produção futura:
# RTK_API_MODE=production
# RTK_API_URL_PRODUCTION=
# RTK_API_KEY_PRODUCTION=

# Stripe (cartão / assinatura)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_MENSAL=
# STRIPE_PRICE_TRIMESTRAL=
# STRIPE_PRICE_ANUAL=

# Mercado Pago (PIX)
# MERCADOPAGO_ACCESS_TOKEN=

# URL pública do app (checkout redirects)
# NEXT_PUBLIC_APP_URL=https://seu-dominio.com.br

# Provedor fiscal (internal | nfeio | focusnfe | plugnotas)
# FISCAL_PROVIDER=internal

# Provedor RTK (rtkdata | snip | emlid-caster | bkg-caster | custom-caster)
# RTK_PROVIDER=rtkdata

# Sentry (observability)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
